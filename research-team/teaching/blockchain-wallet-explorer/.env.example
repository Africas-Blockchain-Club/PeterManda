# Copy this file to .env and fill in your values
# Never commit .env to git

# Your Ethereum RPC URL (get a free one from https://www.alchemy.com or https://infura.io)
# For testnets: use Sepolia or Holesky
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# ERC20 token contract address to track (example: USDC on mainnet)
TOKEN=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48

# A contract address whose token balance you want to check (e.g. a DEX, protocol, etc.)
CONTRACT=0x0000000000000000000000000000000000000000

# Optional: Etherscan API key for faster transaction history lookups
# Get a free key at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=
