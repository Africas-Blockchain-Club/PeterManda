OPENROUTER_API_KEY=sk-or-...
GOOGLE_API_KEY=AIza...
GROQ_API_KEY=gsk_...
COINGLASS_API_KEY=...
ANTHROPIC_API_KEY=sk-ant-...

# Optional — increases CoinGecko rate limits from 30 to 500 req/min
# Free key at: https://www.coingecko.com/en/api
COINGECKO_API_KEY=CG-...

# Optional — enables Reddit subscriber counts (completely free, takes 2 minutes)
#
# How to get your Reddit credentials:
# 1. Log in to Reddit at reddit.com
# 2. Go to reddit.com/prefs/apps
# 3. Scroll to the bottom and click "create an app" (or "create another app")
# 4. Fill in the form:
#      name: ABCResearch (or anything you like)
#      type: select "script"
#      description: leave blank
#      redirect uri: http://localhost:8080 (required but not used)
# 5. Click "create app"
# 6. You will see your app listed. The client id is the short string directly
#    UNDER the app name (looks like: abc123XYZ). The secret is labeled "secret".
# 7. Copy both values below.
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_secret_here
