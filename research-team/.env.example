ANTHROPIC_API_KEY=sk-ant-...

# Optional — derivatives data (funding rates, liquidations)
COINGLASS_API_KEY=...

# Optional — increases CoinGecko rate limits from 30 to 500 req/min
# Free key at: https://www.coingecko.com/en/api
COINGECKO_API_KEY=CG-...

# Optional — enables Reddit subscriber counts (completely free, takes 2 minutes)
#
# How to get your Reddit credentials:
# 1. Log in to Reddit at reddit.com
# 2. Go to reddit.com/prefs/apps
# 3. Scroll to the bottom and click "create an app" (or "create another app")
# 4. Fill in the form:
#      name: ABCResearch (or anything you like)
#      type: select "script"
#      description: leave blank
#      redirect uri: http://localhost:8080 (required but not used)
# 5. Click "create app"
# 6. You will see your app listed. The client id is the short string directly
#    UNDER the app name (looks like: abc123XYZ). The secret is labeled "secret".
# 7. Copy both values below.
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_secret_here

# Email — sends the finished report/receipt to a payer after a paid report is generated
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
TEST_EMAIL_RECIPIENT=

# Postgres connection string — stores payment records and generated reports
# Local dev: postgresql://user:pass@localhost:5432/research_team or sqlite:///local_dev.db
DATABASE_URL=

# Optional — on-chain transaction lookups (Etherscan-family unified API covers Base Sepolia
# via the chainid param using the same key) and fallback payment verification
ETHERSCAN_API_KEY=
BLOCKSCOUT_API_KEY=

# Paid report generation — verified on-chain before the AI call runs.
# Chain: Base Sepolia (84532). Asset: testnet USDC.
CHAIN_ID=84532
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
USDC_CONTRACT_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
REPORT_RECIPIENT_ADDRESS=0x95CD2382EB8DF97fC1e0f3adAA1A9a97FB2b9431
REPORT_PRICE_USDC=1.10

# x402 payment demo (local anvil testnet)
# Defaults to anvil account 0 private key — safe for local testing only, never use on mainnet
X402_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
X402_PAYWALL_URL=http://localhost:5402
X402_RPC_URL=http://127.0.0.1:8545
